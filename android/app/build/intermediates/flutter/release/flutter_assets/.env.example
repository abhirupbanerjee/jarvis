# ── Gemini Live ──
GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-latest
GEMINI_TEMPERATURE=0.7
GEMINI_VOICE=Puck
# Direct API key (development only — never ship to production)
GEMINI_API_KEY=
# Ephemeral token endpoint (production — set both to enable secure mode)
GEMINI_TOKEN_ENDPOINT=
TOKEN_SHARED_SECRET=

# ── Tavily Search ──
TAVILY_API_KEY=
